#!/bin/bash

# Unisphere Endpoint
export  Endpoint="https://10.228.204.17:8443"

# Unisphere username
export  Username="smc"

# Unisphere password
export  Password="smc"

# Unisphere API version
export  APIVersion="XX"

# Symmetrix ID managed by Unisphere
export  SymmetrixID="000120000548"

# Symmetrix ID managed by Unisphere
export RemoteSymmetrixID="000120000549"

#RDF Port number for local and remote array
export  LocalRDFGrpNo="717"
export  RemoteRDFGrpInfo="717"

# Default Mode for Replication
export DefaultRepMode="ASYNC"


# Existing port group for fibre channel connection
export  DefaultFCPortGroup="fc-port-group"

# Existing port group for iSCSI connection
export  DefaultiSCSIPortGroup="csi_pg2"

# Initiators for FC
export  DefaultFCInitiator="OR-4C:1:10000000c9fc06fe"
export  FCInitiator1="10000000c9fc06ff"
export  FCInitiator2="10000000c9fc3b3a"

# Initiators for iSCSI
export  DefaultiSCSIInitiator="OR-2C:000:"iqn.1994-05.com.redhat:1bb952cdb4a"
export  ISCSIInitiator1="iqn.1994-05.com.redhat:2d7cb0b2503a"
export  ISCSIInitiator2="iqn.1994-05.com.redhat:84e03cb58276"

# Storage pool to allocate storage from
export  DefaultStoragePool="SRP_1"

# Service level to be used for volume provisioning
export  DefaultServiceLevel="Diamond"

# Prefix to be added to volume names created by the tests
export  VolumePrefix="xx"

# Prefix to be added to the storage group names created by the tests
export  SGPrefix="zz"

# Prefix to be added to the snapshots names created by the tests
export  SnapPrefix="snap"
# DirectorName
export DefaultFCDirName="OR-4C"

#PortName
export DefaultFCPortName="1"

# ISCSIDirectorName
export DefaultISCSIDirName="OR-2C"

# ISCSIPortName
export DefaultISCSIPortName="0"

#DirectorID
export DefaultFCDirectorID="OR-4C"

# DirectorPortID
export DefaultFCPortID="1"
